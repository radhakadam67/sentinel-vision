# ─── Email alerts (Gmail) — NO extra libraries, uses Python built-in ─────────
# Step 1: Fill in your Gmail address below
# Step 2: Get an App Password (NOT your normal Gmail password):
#           → Go to myaccount.google.com
#           → Security → 2-Step Verification → App Passwords
#           → Create one called "Surveillance Alert"
#           → Paste the 16-char code as EMAIL_APP_PASSWORD below
# Step 3: Set EMAIL_RECEIVER to wherever you want alerts sent (can be same email)

EMAIL_SENDER=your.gmail@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_RECEIVER=your.gmail@gmail.com

# EMAIL_SMTP_HOST=smtp.gmail.com   # default, no need to change
# EMAIL_SMTP_PORT=587               # default, no need to change

CAMERA_NAME=Front Street Camera

# ─── ntfy.sh push notifications (optional — requires ntfy app) ───────────────
# NTFY_TOPIC=radha-surv-alerts-change-this-to-something-secret

# ─── Twilio SMS (optional — requires a Twilio account) ───────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token_here
# TWILIO_FROM_NUMBER=+1415XXXXXXX
# OFFICER_PHONE=+44XXXXXXXXXX

# ─── Webhook (optional) ───────────────────────────────────────────────────────
# ALERT_WEBHOOK_URL=https://your-server.com/alert
